  },
  "peerDependencies": {
    "typescript": "^5",
    "@career-ai/db": "workspace:*",
    "@career-ai/queue": "workspace:*",
    "@career-ai/redis": "workspace:*"
  },
  "dependencies": {
    "zod": "^4.4.2"
  }
}
